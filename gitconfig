[core]
    editor = vim
    autocrlf = input
[user]
    name = Stuart Taylor
    email = 229520+stuartraetaylor@users.noreply.github.com
[merge]
    tool = vimdiff
	directoryRenames = true
[alias]
    co = !git checkout
    cm = !git commit
    amend = !git commit --amend
    push-new = !git push -u origin $(git rev-parse --abbrev-ref HEAD)
    purge = !git branch -D $1 && git push origin --delete $1
    force-pull = !git fetch && git reset --hard origin/$(git rev-parse --abbrev-ref HEAD)
    review = "!f() { \
        git fetch && git checkout origin/$1; \
      }; f"
	pushf = push --force-with-lease --force-if-includes
[log]
    date = iso
[pull]
    rebase = true
[init]
	defaultBranch = main
[credential]
	helper = store
[http]
	postBuffer = 1048576000
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
